<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TPromptHelper.Desktop.ViewModels"
             x:Class="TPromptHelper.Desktop.Views.TokenStatsView"
             x:DataType="vm:TokenStatsViewModel"
             MinWidth="640" MinHeight="400">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Margin="16,12,16,8">
            <Button DockPanel.Dock="Right" Click="OnClearClick"
                    Classes="danger">清空记录</Button>
        </DockPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="20" Margin="16,0,16,16">

                <!-- 汇总卡片 -->
                <TextBlock Text="累计消耗（历史全部）" Classes="section-label" />
                <WrapPanel Orientation="Horizontal">

                    <Border Classes="card" Margin="0,0,12,12" MinWidth="130">
                        <StackPanel Spacing="4">
                            <TextBlock Text="总请求次数" Classes="meta-text" />
                            <TextBlock Text="{Binding TotalRequests}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Margin="0,0,12,12" MinWidth="130">
                        <StackPanel Spacing="4">
                            <TextBlock Text="输入 Token" Classes="meta-text" />
                            <TextBlock Text="{Binding TotalPromptTokens}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Margin="0,0,12,12" MinWidth="130">
                        <StackPanel Spacing="4">
                            <TextBlock Text="输出 Token" Classes="meta-text" />
                            <TextBlock Text="{Binding TotalCompletionTokens}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Margin="0,0,12,12" MinWidth="130">
                        <StackPanel Spacing="4">
                            <TextBlock Text="合计 Token" Classes="meta-text" />
                            <TextBlock Text="{Binding TotalTokens}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Margin="0,0,12,12" MinWidth="180">
                        <StackPanel Spacing="4">
                            <TextBlock Text="预估总费用" Classes="meta-text" />
                            <TextBlock Text="{Binding TotalCostDisplay}" FontSize="20" FontWeight="Bold"
                                       Foreground="#4EC994" />
                        </StackPanel>
                    </Border>

                </WrapPanel>

                <!-- 按模型分组 -->
                <TextBlock Text="按模型分组" Classes="section-label" />

                <!-- 表头 -->
                <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource AppSeparatorBrush}" Padding="8,4">
                    <Grid ColumnDefinitions="*,70,90,90,90,130">
                        <TextBlock Grid.Column="0" Text="模型" Classes="meta-text" />
                        <TextBlock Grid.Column="1" Text="次数"    Classes="meta-text" TextAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="输入 T"  Classes="meta-text" TextAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="输出 T"  Classes="meta-text" TextAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="合计 T"  Classes="meta-text" TextAlignment="Right" />
                        <TextBlock Grid.Column="5" Text="预估费用" Classes="meta-text" TextAlignment="Right" />
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding ModelStats}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ModelUsageStat">
                            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource AppSeparatorBrush}"
                                    Padding="8,7">
                                <Grid ColumnDefinitions="*,70,90,90,90,130">
                                    <StackPanel Grid.Column="0" Spacing="1">
                                        <TextBlock Text="{Binding ModelName}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                        <TextBlock Text="{Binding Provider}" Classes="meta-text" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding RequestCount}"
                                               VerticalAlignment="Center" TextAlignment="Right" />
                                    <TextBlock Grid.Column="2" Text="{Binding PromptTokens}"
                                               VerticalAlignment="Center" TextAlignment="Right" />
                                    <TextBlock Grid.Column="3" Text="{Binding CompletionTokens}"
                                               VerticalAlignment="Center" TextAlignment="Right" />
                                    <TextBlock Grid.Column="4" Text="{Binding TotalTokens}"
                                               VerticalAlignment="Center" TextAlignment="Right" />
                                    <TextBlock Grid.Column="5" Text="{Binding CostDisplay}"
                                               VerticalAlignment="Center" TextAlignment="Right"
                                               Foreground="#4EC994" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="数据持久化保存，重启后仍保留。点击&quot;清空记录&quot;可重置所有统计。"
                           Classes="meta-text" TextWrapping="Wrap" Margin="0,4,0,0" />

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
