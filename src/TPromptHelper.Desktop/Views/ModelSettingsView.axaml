<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TPromptHelper.Desktop.ViewModels"
             xmlns:models="using:TPromptHelper.Core.Models"
             x:Class="TPromptHelper.Desktop.Views.ModelSettingsView"
             x:DataType="vm:ModelSettingsViewModel"
             MinWidth="600" MinHeight="400">

    <Grid ColumnDefinitions="240,*" Margin="16" ColumnSpacing="16">

        <!-- Profile List -->
        <DockPanel Grid.Column="0">
            <Button DockPanel.Dock="Top"
                    Command="{Binding NewProfileCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,8">
                + 新建模型配置
            </Button>
            <ListBox ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding EditingProfile}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ModelProfile">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Provider}" Classes="meta-text" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Profile Editor -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="12" IsVisible="{Binding EditingProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="模型配置" Classes="section-label" />

                <StackPanel Spacing="4">
                    <TextBlock Text="名称" />
                    <TextBox Text="{Binding EditingProfile.Name}" Watermark="我的 GPT-4" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="提供商" />
                    <ComboBox ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding EditingProfile.Provider}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="模型名称" />
                    <TextBox Text="{Binding EditingProfile.ModelName}" Watermark="gpt-4o" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="API Key" />
                    <TextBox Text="{Binding RawApiKey}" PasswordChar="•" Watermark="sk-..." />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="自定义 API 端点（可选）" />
                    <TextBox Text="{Binding EditingProfile.ApiEndpoint}"
                             Watermark="https://api.example.com/v1（填 Base URL 即可）" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="最大 Token" />
                        <NumericUpDown Value="{Binding EditingProfile.MaxTokens}"
                                       Minimum="256" Maximum="32768" Increment="256" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Temperature" />
                        <NumericUpDown Value="{Binding EditingProfile.Temperature}"
                                       Minimum="0" Maximum="2" Increment="0.1"
                                       FormatString="F1" />
                    </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="{DynamicResource AppSeparatorBrush}" />

                <TextBlock Text="计费配置（可选）" Classes="section-label" />

                <StackPanel Spacing="4">
                    <TextBlock Text="货币单位" />
                    <ComboBox ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding EditingProfile.Currency}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="输入价格（每百万 Token）" />
                        <NumericUpDown Value="{Binding EditingProfile.InputPricePer1M}"
                                       Minimum="0" Maximum="9999" Increment="0.1"
                                       FormatString="F4" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="输出价格（每百万 Token）" />
                        <NumericUpDown Value="{Binding EditingProfile.OutputPricePer1M}"
                                       Minimum="0" Maximum="9999" Increment="0.1"
                                       FormatString="F4" />
                    </StackPanel>
                </Grid>

                <CheckBox IsChecked="{Binding EditingProfile.IsDefault}" Content="设为默认模型" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding SaveProfileCommand}" Classes="primary">保存</Button>
                    <Button Command="{Binding DeleteProfileCommand}"
                            CommandParameter="{Binding EditingProfile}"
                            Classes="danger">删除</Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
